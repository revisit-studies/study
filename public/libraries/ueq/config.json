      "type": "questionnaire",
      "response": [
        {
          "id": "ueq-response",
          "prompt": "For each word pair, select a value from 1 (left word) to 7 (right word).",
          "secondaryText": "1 = left word, 7 = right word",
          "required": true,
          "location": "aboveStimulus",
          "type": "matrix-radio",
