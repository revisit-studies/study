{
  "$schema": "https://raw.githubusercontent.com/revisit-studies/study/v2.4.1/src/parser/StudyConfigSchema.json",
  "studyMetadata": {
    "title": "Factors Demo",
    "version": "pilot",
    "authors": ["The reVISit Team"],
    "date": "2023-04-14",
    "description": "A simple demo of using stimuli in an HTML file that renders a D3 visualization. Data is collected via a numeric response field.",
    "organizations": ["University of Utah", "WPI", "University of Toronto"]
  },
  "uiConfig": {
    "contactEmail": "contact@revisit.dev",
    "helpTextPath": "demo-html/assets/help.md",
    "logoPath": "revisitAssets/revisitLogoSquare.svg",
    "withProgressBar": true,
    "autoDownloadStudy": false,
    "withSidebar": true,
    "windowEventDebounceTime": 200
  },
  "baseComponents": {
    "factorComponent": {
      "type": "react-component",
      "path": "demo-factors/assets/Factors.tsx",
      "response": []
    },
    "factorKeywordComponent": {
      "type": "react-component",
      "path": "demo-factors/assets/Factors.tsx",
      "parameters": {
        "atSyntaxLabel": "@data shown as @visType for @task",
        "bracedSyntaxLabel": "${data}/${visType}/${task}",
        "literalEmail": "contact@revisit.dev"
      },
      "response": []
    },
    "nestedFactorKeywordComponent": {
      "type": "react-component",
      "path": "demo-factors/assets/Factors.tsx",
      "parameters": {
        "nestedAtSyntaxLabel": "@zipBlock includes @data and @visType for @task",
        "nestedBracedSyntaxLabel": "${zipBlock}/${data}/${visType}/${task}"
      },
      "response": []
    }
  },
  "components": {
    "Ok_googleTutorialYoung": {
      "type": "markdown",
      "path": "demo-factors/assets/ok-google-tutorial-young.md",
      "response": []
    },
    "Ok_googleTutorialOld": {
      "type": "markdown",
      "path": "demo-factors/assets/ok-google-tutorial-old.md",
      "response": []
    }
  },
  "factors": {
    "data": ["d1", "d2"],
    "visType": ["v1", "v2", "v3"],
    "task": ["t1", "t2", "t3"],
    "ageGroup": ["young", "old"],
    "learningStrategies": ["monologue", "scaffolding", "conceptual"],
    "topics": ["sleep", "cholesterol", "alzheimer", "vitamin", "sugar", "flu"],
    "crossBlock": {
      "action": "cross",
      "order": "fixed",
      "values": [
        {
          "factor": "data"
        },
        {
          "factor": "visType"
        }
      ]
    },
    "nestBlock": {
      "action": "nest",
      "values": [
        {
          "factor": "data"
        },
        {
          "factor": "visType"
        }
      ]
    },
    "zipBlock": {
      "action": "zip",
      "order": "latinSquare",
      "values": [
        {
          "factor": "data"
        },
        {
          "factor": "visType"
        }
      ]
    },
    "zipThenTaskBlock": {
      "action": "nest",
      "order": "random",
      "values": [
        {
          "factor": "zipBlock"
        },
        {
          "factor": "task"
        }
      ]
    },
    "crossZipWithTaskBlock": {
      "action": "cross",
      "order": "fixed",
      "values": [
        {
          "factor": "zipBlock"
        },
        {
          "factor": "task"
        }
      ]
    },
    "zipZipWithTaskBlock": {
      "action": "zip",
      "order": "fixed",
      "values": [
        {
          "factor": "zipBlock"
        },
        {
          "factor": "task"
        }
      ]
    },
    "nestCrossWithTaskBlock": {
      "action": "nest",
      "order": "latinSquare",
      "values": [
        {
          "factor": "crossBlock"
        },
        {
          "factor": "task"
        }
      ]
    },
    "sampledPrimitiveBlock": {
      "action": "nest",
      "order": "fixed",
      "values": [
        {
          "factor": "data"
        },
        {
          "factor": "visType",
          "numSamples": 2
        },
        {
          "factor": "task",
          "numSamples": 2
        }
      ]
    },
    "sampledDerivedBlock": {
      "action": "nest",
      "order": "fixed",
      "values": [
        {
          "factor": "zipBlock",
          "numSamples": 1
        },
        {
          "factor": "task",
          "numSamples": 2
        }
      ]
    },
    "factorKeywordBlock": {
      "action": "nest",
      "order": "fixed",
      "values": [
        {
          "factor": "data",
          "numSamples": 1
        },
        {
          "factor": "visType",
          "numSamples": 1
        },
        {
          "factor": "task",
          "numSamples": 1
        }
      ]
    },
    "concatBlock": {
      "action": "concat",
      "order": "fixed",
      "values": [
        {
          "factor": "data"
        },
        {
          "factor": "task",
          "numSamples": 2
        }
      ]
    },
    "repeatBlock": {
      "action": "repeat",
      "order": "fixed",
      "numRepeats": 2,
      "values": [
        {
          "factor": "visType"
        }
      ]
    },
    "Ok_googleLearningStrategySlots": {
      "action": "repeat",
      "order": "fixed",
      "numRepeats": 2,
      "values": [
        {
          "factor": "learningStrategies"
        }
      ]
    },
    "Ok_googleTopicAssignments": {
      "action": "zip",
      "order": "random",
      "values": [
        {
          "factor": "Ok_googleLearningStrategySlots"
        },
        {
          "factor": "topics",
          "numSamples": 6
        }
      ]
    },
    "Ok_google": {
      "action": "nest",
      "order": "fixed",
      "values": [
        {
          "factor": "ageGroup"
        },
        {
          "factor": "Ok_googleTopicAssignments"
        }
      ]
    }
  },
  "betweenSubjectsFactors": ["ageGroup"],
  "sequence": {
    "order": "fixed",
    "components": [
      {
        "type": "factor",
        "factor": "crossBlock",
        "component": "factorComponent"
      },
      {
        "type": "factor",
        "factor": "nestBlock",
        "component": "factorComponent"
      },
      {
        "type": "factor",
        "factor": "zipBlock",
        "component": "factorComponent"
      },
      {
        "type": "factor",
        "factor": "zipThenTaskBlock",
        "component": "factorComponent"
      },
      {
        "type": "factor",
        "factor": "crossZipWithTaskBlock",
        "component": "factorComponent"
      },
      {
        "type": "factor",
        "factor": "zipZipWithTaskBlock",
        "component": "nestedFactorKeywordComponent"
      },
      {
        "type": "factor",
        "factor": "nestCrossWithTaskBlock",
        "component": "factorComponent"
      },
      {
        "type": "factor",
        "factor": "sampledPrimitiveBlock",
        "component": "factorComponent"
      },
      {
        "type": "factor",
        "factor": "sampledDerivedBlock",
        "component": "factorComponent"
      },
      {
        "type": "factor",
        "factor": "factorKeywordBlock",
        "component": "factorKeywordComponent"
      },
      {
        "type": "factor",
        "factor": "concatBlock",
        "component": "factorComponent"
      },
      {
        "type": "factor",
        "factor": "repeatBlock",
        "component": "factorComponent"
      },
      {
        "id": "Ok_googleTutorialByAgeGroup",
        "order": "fixed",
        "components": [
          {
            "id": "Ok_googleTutorialYoungBlock",
            "order": "fixed",
            "parameters": {
              "ageGroup": "young"
            },
            "components": ["Ok_googleTutorialYoung"]
          },
          {
            "id": "Ok_googleTutorialOldBlock",
            "order": "fixed",
            "parameters": {
              "ageGroup": "old"
            },
            "components": ["Ok_googleTutorialOld"]
          }
        ]
      },
      {
        "type": "factor",
        "factor": "Ok_google",
        "component": "factorComponent"
      },
      {
        "type": "factor",
        "factor": "nestBlock",
        "component": "factorComponent",
        "id": "nestBlockFixedReuse",
        "order": "fixed"
      },
      {
        "type": "factor",
        "factor": "crossZipWithTaskBlock",
        "component": "factorComponent",
        "id": "crossZipWithTaskRandomReuse",
        "order": "random"
      }
    ]
  }
}
