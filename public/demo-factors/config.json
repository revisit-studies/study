{
  "$schema": "https://raw.githubusercontent.com/revisit-studies/study/v2.4.1/src/parser/StudyConfigSchema.json",
  "studyMetadata": {
    "title": "Factors Demo",
    "version": "pilot",
    "authors": ["The reVISit Team"],
    "date": "2023-04-14",
    "description": "A simple demo of using stimuli in an HTML file that renders a D3 visualization. Data is collected via a numeric response field.",
    "organizations": ["University of Utah", "WPI", "University of Toronto"]
  },
  "uiConfig": {
    "contactEmail": "contact@revisit.dev",
    "helpTextPath": "demo-html/assets/help.md",
    "logoPath": "revisitAssets/revisitLogoSquare.svg",
    "withProgressBar": true,
    "autoDownloadStudy": false,
    "withSidebar": true,
    "windowEventDebounceTime": 200
  },
  "baseComponents": {
    "factorComponent": {
      "type": "react-component",
      "path": "demo-factors/assets/Factors.tsx",
      "response": []
    }
  },
  "components": {},
  "factors": {
    "data": ["d1", "d2"],
    "visType": ["v1", "v2", "v3"],
    "task": ["t1", "t2", "t3"]
  },
  "factorBlocks": {
    "crossBlock": {
      "action": "cross",
      "order": "fixed",
      "factorsToCross": [
        {
          "factor": "data"
        },
        {
          "factor": "visType"
        }
      ],
      "component": "factorComponent"
    },
    "nestBlock": {
      "action": "nest",
      "factorsToCross": [
        {
          "factor": "data"
        },
        {
          "factor": "visType"
        }
      ],
      "component": "factorComponent"
    },
    "zipBlock": {
      "action": "zip",
      "order": "latinSquare",
      "factorsToCross": [
        {
          "factor": "data"
        },
        {
          "factor": "visType"
        }
      ],
      "component": "factorComponent"
    },
    "zipThenTaskBlock": {
      "action": "nest",
      "order": "random",
      "factorsToCross": [
        {
          "factorBlock": "zipBlock"
        },
        {
          "factor": "task"
        }
      ],
      "component": "factorComponent"
    },
    "crossZipWithTaskBlock": {
      "action": "cross",
      "order": "fixed",
      "factorsToCross": [
        {
          "factorBlock": "zipBlock"
        },
        {
          "factor": "task"
        }
      ],
      "component": "factorComponent"
    },
    "zipZipWithTaskBlock": {
      "action": "zip",
      "order": "fixed",
      "factorsToCross": [
        {
          "factorBlock": "zipBlock"
        },
        {
          "factor": "task"
        }
      ],
      "component": "factorComponent"
    },
    "nestCrossWithTaskBlock": {
      "action": "nest",
      "order": "latinSquare",
      "factorsToCross": [
        {
          "factorBlock": "crossBlock"
        },
        {
          "factor": "task"
        }
      ],
      "component": "factorComponent"
    }
  },
  "sequence": {
    "order": "fixed",
    "components": [
      {
        "type": "factorBlock",
        "factorBlock": "crossBlock"
      },
      {
        "type": "factorBlock",
        "factorBlock": "nestBlock"
      },
      {
        "type": "factorBlock",
        "factorBlock": "zipBlock"
      },
      {
        "type": "factorBlock",
        "factorBlock": "zipThenTaskBlock"
      },
      {
        "type": "factorBlock",
        "factorBlock": "crossZipWithTaskBlock"
      },
      {
        "type": "factorBlock",
        "factorBlock": "zipZipWithTaskBlock"
      },
      {
        "type": "factorBlock",
        "factorBlock": "nestCrossWithTaskBlock"
      },
      {
        "type": "factorBlock",
        "factorBlock": "nestBlock",
        "id": "nestBlockFixedReuse",
        "order": "fixed"
      },
      {
        "type": "factorBlock",
        "factorBlock": "crossZipWithTaskBlock",
        "id": "crossZipWithTaskRandomReuse",
        "order": "random"
      }
    ]
  }
}
